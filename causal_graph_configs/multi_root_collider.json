{
  "graph_id": "multi_root_collider",
  "description": "Multiple roots converging: A -> D, B -> D, C -> D (Three independent causes)",
  "nodes": {
    "A": {
      "is_controllable": true,
      "property_name": "temperatureC",
      "base_value": {
        "type": "uniform",
        "min": 10.0,
        "max": 50.0
      }
    },
    "B": {
      "is_controllable": true,
      "property_name": "density",
      "base_value": {
        "type": "uniform",
        "min": 10.0,
        "max": 70.0
      }
    },
    "C": {
      "is_controllable": true,
      "property_name": "moisture",
      "base_value": {
        "type": "uniform",
        "min": 5.0,
        "max": 25.0
      }
    },
    "D": {
      "is_controllable": false,
      "property_name": "resonanceFreq",
      "computation": "base + coeff_a * A + coeff_b * B + coeff_c * C"
    }
  },
  "edges": [
    {"from": "A", "to": "D"},
    {"from": "B", "to": "D"},
    {"from": "C", "to": "D"}
  ],
  "params": {
    "base": 500.0,
    "coeff_a": 20.0,
    "coeff_b": 8.0,
    "coeff_c": 12.0
  }
}




